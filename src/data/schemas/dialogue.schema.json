{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "keystone/dialogue.schema.json",
  "title": "Keystone Dialogue",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["lines"],
    "additionalProperties": false,
    "properties": {
      "lines": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["who", "text"],
          "additionalProperties": false,
          "properties": {
            "who": { "type": "string" },
            "text": { "type": "string" },
            "portrait": { "type": "string" }
          }
        }
      },
      "setFlag": { "type": "string", "pattern": "^[a-z0-9_]+$" },
      "startQuest": { "type": "string", "pattern": "^[qs][0-9]+_[a-z0-9_]+$" },
      "giveItem": { "type": "string" },
      "takeItem": { "type": "string" },
      "completeStep": {
        "type": "object",
        "required": ["id", "step"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "step": { "type": "string" }
        }
      },
      "requires": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "flag": { "type": "string" },
          "notFlag": { "type": "string" },
          "item": { "type": "string" },
          "questAt": {
            "type": "object",
            "required": ["id", "step"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "step": { "type": "string" }
            }
          },
          "questDone": { "type": "string" }
        }
      }
    }
  }
}
